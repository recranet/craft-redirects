{
	"name": "recranet/craft-redirects",
	"description": "Simple redirect management for Craft CMS",
	"version": "1.0.0",
	"type": "craft-plugin",
	"require": {
		"craftcms/cms": "^5.0"
	},
	"autoload": {
		"psr-4": {
			"recranet\\redirects\\": "src/"
		}
	},
	"extra": {
		"handle": "redirects",
		"name": "Redirects",
		"developer": "Recranet",
		"class": "recranet\\redirects\\Redirects"
	}
}
