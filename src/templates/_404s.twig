{% extends '_layouts/cp' %}

{% set title = '404 Log'|t('redirects') %}
{% set selectedSubnavItem = '404s' %}
{% set fullPageForm = false %}

{% block actionButton %}
    {% if notFounds|length %}
        <button class="btn caution" id="clearAll404s">{{ 'Clear all'|t('redirects') }}</button>
    {% endif %}
{% endblock %}

{% block content %}
    {# Site filter #}
    {% if sites|length > 1 %}
        <div style="margin-bottom: 16px; display: flex; align-items: center; gap: 12px;">
            <label for="siteFilter" style="font-weight: 600;">{{ 'Site'|t('redirects') }}:</label>
            <select id="siteFilter" class="text" onchange="window.location.href='{{ cpUrl('redirects/404s') }}' + (this.value ? '?siteId=' + this.value : '')">
                <option value="">{{ 'All Sites'|t('redirects') }}</option>
                {% for site in sites %}
                    <option value="{{ site.id }}" {% if selectedSiteId == site.id %}selected{% endif %}>{{ site.name }}</option>
                {% endfor %}
            </select>
        </div>
    {% endif %}

    {% if notFounds|length %}
        <div style="margin-bottom: 16px;">
            <input type="text" id="notFoundSearch" class="text fullwidth" placeholder="{{ 'Search 404s...'|t('redirects') }}" style="max-width: 400px;">
        </div>

        <table class="data fullwidth sortable-table">
            <thead>
                <tr>
                    <th class="sortable" data-sort="string" data-index="0">{{ 'URL'|t('redirects') }}</th>
                    {% if sites|length > 1 %}
                        <th class="sortable" data-sort="string" data-index="1">{{ 'Site'|t('redirects') }}</th>
                    {% endif %}
                    <th class="sortable" data-sort="number" data-index="{{ sites|length > 1 ? 2 : 1 }}">{{ 'Hits'|t('redirects') }}</th>
                    <th class="sortable" data-sort="string" data-index="{{ sites|length > 1 ? 3 : 2 }}">{{ 'Last Hit'|t('redirects') }}</th>
                    <th class="sortable" data-sort="string" data-index="{{ sites|length > 1 ? 4 : 3 }}">{{ 'First Seen'|t('redirects') }}</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for nf in notFounds %}
                    <tr data-id="{{ nf.id }}">
                        <td>{{ nf.url }}</td>
                        {% if sites|length > 1 %}
                            <td>{{ nf.siteName }}</td>
                        {% endif %}
                        <td>{{ nf.hitCount }}</td>
                        <td>{{ nf.lastHitAt }}</td>
                        <td>{{ nf.dateCreated }}</td>
                        <td class="thin" style="white-space: nowrap;">
                            <a href="{{ cpUrl('redirects/new', { fromUrl: nf.url, siteId: nf.siteId }) }}" class="btn small submit" title="{{ 'Create redirect'|t('redirects') }}">{{ 'Create redirect'|t('redirects') }}</a>
                            <button class="btn small delete-404" data-id="{{ nf.id }}" title="{{ 'Delete'|t('redirects') }}">{{ 'Delete'|t('redirects') }}</button>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>{{ 'No 404s logged yet.'|t('redirects') }}</p>
    {% endif %}

    {% css %}
        .sortable-table th.sortable {
            cursor: pointer;
            user-select: none;
            white-space: nowrap;
        }
        .sortable-table th.sortable:hover {
            background-color: rgba(0, 0, 0, 0.05);
        }
        .sortable-table th.sortable::after {
            content: '';
            display: inline-block;
            width: 0;
            height: 0;
            margin-left: 5px;
            vertical-align: middle;
            border-left: 4px solid transparent;
            border-right: 4px solid transparent;
            border-top: 4px solid transparent;
            border-bottom: 4px solid transparent;
        }
        .sortable-table th.sortable.sort-asc::after {
            border-bottom: 4px solid currentColor;
            border-top: none;
        }
        .sortable-table th.sortable.sort-desc::after {
            border-top: 4px solid currentColor;
            border-bottom: none;
        }
        .btn.caution {
            color: #dc2626;
        }
    {% endcss %}

    {% js %}
        // Search
        (function() {
            var input = document.getElementById('notFoundSearch');
            if (!input) return;

            input.addEventListener('input', function() {
                var query = this.value.toLowerCase();
                document.querySelectorAll('.sortable-table tbody tr').forEach(function(row) {
                    var text = row.textContent.toLowerCase();
                    row.style.display = text.includes(query) ? '' : 'none';
                });
            });
        })();

        // Sortable table
        (function() {
            var table = document.querySelector('.sortable-table');
            if (!table) return;

            var headers = table.querySelectorAll('th.sortable');
            var tbody = table.querySelector('tbody');
            var currentSort = { index: null, dir: 'asc' };

            headers.forEach(function(th) {
                th.addEventListener('click', function() {
                    var index = parseInt(th.dataset.index);
                    var type = th.dataset.sort;

                    if (currentSort.index === index) {
                        currentSort.dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
                    } else {
                        currentSort.index = index;
                        currentSort.dir = 'asc';
                    }

                    headers.forEach(function(h) { h.classList.remove('sort-asc', 'sort-desc'); });
                    th.classList.add('sort-' + currentSort.dir);

                    var rows = Array.from(tbody.querySelectorAll('tr'));
                    rows.sort(function(a, b) {
                        var cellA = a.children[index];
                        var cellB = b.children[index];
                        var valA = cellA.textContent.trim().toLowerCase();
                        var valB = cellB.textContent.trim().toLowerCase();

                        if (type === 'number') {
                            valA = parseFloat(valA) || 0;
                            valB = parseFloat(valB) || 0;
                        }

                        var result = valA > valB ? 1 : valA < valB ? -1 : 0;
                        return currentSort.dir === 'desc' ? -result : result;
                    });

                    rows.forEach(function(row) { tbody.appendChild(row); });
                });
            });
        })();

        // Delete single 404
        document.querySelectorAll('.delete-404').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var id = this.dataset.id;
                var row = this.closest('tr');

                Craft.sendActionRequest('POST', 'redirects/redirects/delete-404', {
                    data: { id: id }
                }).then(function() {
                    row.remove();
                    Craft.cp.displayNotice('{{ '404 entry removed.'|t('redirects')|e('js') }}');
                }).catch(function() {
                    Craft.cp.displayError('{{ 'Could not delete 404 entry.'|t('redirects')|e('js') }}');
                });
            });
        });

        // Clear all 404s
        var clearBtn = document.getElementById('clearAll404s');
        if (clearBtn) {
            clearBtn.addEventListener('click', function() {
                if (!confirm('{{ 'Are you sure you want to clear all 404 entries?'|t('redirects')|e('js') }}')) {
                    return;
                }

                Craft.sendActionRequest('POST', 'redirects/redirects/delete-all-404s', {
                    data: { siteId: '{{ selectedSiteId }}' }
                })
                    .then(function() {
                        window.location.reload();
                    }).catch(function() {
                        Craft.cp.displayError('{{ 'Could not clear 404 log.'|t('redirects')|e('js') }}');
                    });
            });
        }
    {% endjs %}
{% endblock %}
