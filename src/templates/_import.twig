{% extends '_layouts/cp' %}

{% set title = 'Import Redirects' %}
{% set selectedSubnavItem = 'import' %}

{% block content %}
    <form method="post" enctype="multipart/form-data">
        {{ csrfInput() }}
        {{ actionInput('redirects/redirects/upload-csv') }}

        <div class="field">
            <div class="heading">
                <label for="csvFile">CSV File</label>
                <div class="instructions">
                    <p>Upload a CSV file with redirect data. The first row should contain column headers. Column mapping happens in the next step.</p>
                </div>
            </div>
            <div class="input">
                <input type="file" id="csvFile" name="csvFile" accept=".csv,.txt">
            </div>
        </div>

        <div class="btngroup">
            <button type="submit" id="uploadBtn" class="btn" disabled>Upload & Preview</button>
        </div>
    </form>

    <hr style="margin: 24px 0;">

    <h2>Example CSV</h2>
    <p>Not sure about the format?</p>
    <a href="{{ actionUrl('redirects/redirects/download-example-csv') }}" class="btn">Download example CSV</a>

    <table class="data fullwidth" style="margin-top: 12px;">
        <thead>
            <tr>
                <th>from</th>
                <th>to</th>
                <th>type</th>
                <th>label</th>
                <th>notes</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>/old-page</td>
                <td>/new-page</td>
                <td>301</td>
                <td>Livegang</td>
                <td>Homepage moved</td>
            </tr>
            <tr>
                <td>/blog/old-post</td>
                <td>/articles/new-post</td>
                <td>301</td>
                <td>Redesign</td>
                <td>Blog restructured</td>
            </tr>
            <tr>
                <td>/promo</td>
                <td>https://example.com/campaign</td>
                <td>302</td>
                <td>Campagne</td>
                <td>Temporary promo redirect</td>
            </tr>
        </tbody>
    </table>
    </form>
    {% js %}
        (function() {
            var fileInput = document.getElementById('csvFile');
            var uploadBtn = document.getElementById('uploadBtn');
            if (!fileInput || !uploadBtn) return;

            fileInput.addEventListener('change', function() {
                var hasFile = !!this.files.length;
                uploadBtn.disabled = !hasFile;
                uploadBtn.classList.toggle('submit', hasFile);
            });
        })();
    {% endjs %}
{% endblock %}
