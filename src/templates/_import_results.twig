{% extends '_layouts/cp' %}

{% set title = 'Import Results'|t('redirects') %}
{% set selectedSubnavItem = 'import' %}

{% block content %}
    <div class="field">
        <p>{{ '{imported} of {total} redirects imported successfully.'|t('redirects', { imported: '<strong>' ~ imported ~ '</strong>', total: '<strong>' ~ total ~ '</strong>' })|raw }}</p>
    </div>

    {% if errors|length %}
        <h2>{{ 'Errors'|t('redirects') }}</h2>
        <table class="data fullwidth" style="margin-top: 8px;">
            <thead>
                <tr>
                    <th>{{ 'Row'|t('redirects') }}</th>
                    <th>{{ 'Data'|t('redirects') }}</th>
                    <th>{{ 'Errors'|t('redirects') }}</th>
                </tr>
            </thead>
            <tbody>
                {% for error in errors %}
                    <tr>
                        <td>{{ error.row }}</td>
                        <td>
                            {% for key, value in error.data %}
                                <strong>{{ key }}:</strong> {{ value }}<br>
                            {% endfor %}
                        </td>
                        <td>
                            {% for field, messages in error.errors %}
                                {% for message in messages %}
                                    {{ message }}<br>
                                {% endfor %}
                            {% endfor %}
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% endif %}

    <div class="btngroup" style="margin-top: 16px;">
        <a href="{{ cpUrl('redirects/import') }}" class="btn submit">{{ 'Import more'|t('redirects') }}</a>
        <a href="{{ cpUrl('redirects') }}" class="btn">{{ 'View redirects'|t('redirects') }}</a>
    </div>
{% endblock %}
