{% extends '_layouts/cp' %}
{% import '_includes/forms' as forms %}

{% set title = redirect.id ? 'Edit redirect'|t('redirects') : 'New redirect'|t('redirects') %}
{% set selectedSubnavItem = 'redirects' %}
{% set fullPageForm = true %}

{% block content %}
    {{ actionInput('redirects/redirects/save') }}
    {{ redirectInput('redirects') }}

    {% if redirect.id %}
        {{ hiddenInput('id', redirect.id) }}
    {% endif %}

    {{ forms.lightswitchField({
        label: 'Enabled'|t('redirects'),
        instructions: 'Whether this redirect is active.'|t('redirects'),
        id: 'enabled',
        name: 'enabled',
        on: redirect.enabled,
    }) }}

    {{ forms.selectField({
        label: 'Match Type'|t('redirects'),
        instructions: '<strong>Exact match</strong>: matches the URL literally. <strong>Regex</strong>: use a regex pattern (without delimiters). Use <code>$1</code>, <code>$2</code> etc. in the To URL for captured groups.'|t('redirects'),
        id: 'matchType',
        name: 'matchType',
        value: redirect.matchType,
        options: matchTypeOptions,
        errors: redirect.getErrors('matchType'),
    }) }}

    {{ forms.textField({
        label: 'From URL'|t('redirects'),
        instructions: redirect.matchType == 'regex'
            ? 'Regex pattern without delimiters, e.g. <code>^/blog/(.*)$</code>'|t('redirects')
            : 'The path to redirect from. Must start with <code>/</code>.'|t('redirects'),
        id: 'fromUrl',
        name: 'fromUrl',
        value: redirect.fromUrl,
        required: true,
        errors: redirect.getErrors('fromUrl'),
        placeholder: redirect.matchType == 'regex' ? '^/blog/(.*)$' : '/old-page',
    }) }}

    {{ forms.textField({
        label: 'To URL'|t('redirects'),
        instructions: redirect.matchType == 'regex'
            ? 'Destination URL. Use <code>$1</code>, <code>$2</code> for captured groups, e.g. <code>/articles/$1</code>'|t('redirects')
            : 'The destination URL. Can be a relative path or absolute URL.'|t('redirects'),
        id: 'toUrl',
        name: 'toUrl',
        value: redirect.toUrl,
        required: true,
        errors: redirect.getErrors('toUrl'),
        placeholder: redirect.matchType == 'regex' ? '/articles/$1' : '/new-page or https://example.com',
    }) }}

    {{ forms.selectField({
        label: 'Type'|t('redirects'),
        instructions: 'The HTTP status code for the redirect. <a href="https://developer.mozilla.org/en-US/docs/Web/HTTP/Status#redirection_messages" target="_blank" rel="noopener">Learn more on MDN</a>.'|t('redirects'),
        id: 'type',
        name: 'type',
        value: redirect.type,
        options: typeOptions,
        errors: redirect.getErrors('type'),
    }) }}

    {{ forms.textField({
        label: 'Label'|t('redirects'),
        instructions: 'Optional label to categorize this redirect, e.g. "Livegang", "Redesign".'|t('redirects'),
        id: 'label',
        name: 'label',
        value: redirect.label,
        errors: redirect.getErrors('label'),
        placeholder: 'e.g. Livegang',
    }) }}

    {{ forms.textareaField({
        label: 'Notes'|t('redirects'),
        instructions: 'Optional notes about this redirect.'|t('redirects'),
        id: 'notes',
        name: 'notes',
        value: redirect.notes,
        rows: 3,
        errors: redirect.getErrors('notes'),
    }) }}
{% endblock %}
