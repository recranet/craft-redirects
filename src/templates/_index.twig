{% extends '_layouts/cp' %}

{% set title = 'Redirects'|t('redirects') %}
{% set selectedSubnavItem = 'redirects' %}
{% set fullPageForm = false %}

{% block actionButton %}
    <a href="{{ actionUrl('redirects/redirects/export', { siteId: selectedSiteId }) }}" class="btn">{{ 'Export CSV'|t('redirects') }}</a>
    <a href="{{ cpUrl('redirects/new') }}" class="btn submit">{{ 'New redirect'|t('redirects') }}</a>
{% endblock %}

{% block content %}
    {# Site filter #}
    {% if sites|length > 1 %}
        <div style="margin-bottom: 16px; display: flex; align-items: center; gap: 12px;">
            <label for="siteFilter" style="font-weight: 600;">{{ 'Site'|t('redirects') }}:</label>
            <select id="siteFilter" class="text" onchange="window.location.href='{{ cpUrl('redirects') }}' + (this.value ? '?siteId=' + this.value : '')">
                <option value="">{{ 'All Sites'|t('redirects') }}</option>
                {% for site in sites %}
                    <option value="{{ site.id }}" {% if selectedSiteId == site.id %}selected{% endif %}>{{ site.name }}</option>
                {% endfor %}
            </select>
        </div>
    {% endif %}

    {% if redirects|length %}
        {# Search bar #}
        <div style="margin-bottom: 16px; display: flex; align-items: center; gap: 12px;">
            <input type="text" id="redirectSearch" class="text fullwidth" placeholder="{{ 'Search redirects...'|t('redirects') }}" style="max-width: 400px;">
        </div>

        {# Bulk action bar (hidden by default) #}
        <div id="bulkActions" style="display: none; margin-bottom: 16px; padding: 10px 14px; background: #f1f5f9; border-radius: 6px; align-items: center; gap: 10px;">
            <span id="bulkCount">0</span> {{ 'selected'|t('redirects') }} —
            <button class="btn small" id="bulkEnableBtn">{{ 'Enable'|t('redirects') }}</button>
            <button class="btn small" id="bulkDisableBtn">{{ 'Disable'|t('redirects') }}</button>
            <button class="btn small caution" id="bulkDeleteBtn">{{ 'Delete'|t('redirects') }}</button>
            <span style="margin-left: 8px; border-left: 1px solid #cbd5e1; padding-left: 10px;">
                <select id="bulkTypeSelect" class="text">
                    <option value="302">302</option>
                    <option value="301">301</option>
                    <option value="307">307</option>
                    <option value="308">308</option>
                </select>
                <button class="btn small" id="bulkChangeTypeBtn">{{ 'Change type'|t('redirects') }}</button>
            </span>
        </div>

        <table class="data fullwidth sortable-table">
            <thead>
                <tr>
                    <th style="width: 30px;"><input type="checkbox" id="selectAll"></th>
                    <th class="sortable" data-sort="string" data-index="1">{{ 'Enabled'|t('redirects') }}</th>
                    {% if sites|length > 1 %}
                        <th class="sortable" data-sort="string" data-index="2">{{ 'Site'|t('redirects') }}</th>
                    {% endif %}
                    <th class="sortable" data-sort="string" data-index="{{ sites|length > 1 ? 3 : 2 }}">{{ 'From'|t('redirects') }}</th>
                    <th class="sortable" data-sort="string" data-index="{{ sites|length > 1 ? 4 : 3 }}">{{ 'To'|t('redirects') }}</th>
                    <th class="sortable" data-sort="number" data-index="{{ sites|length > 1 ? 5 : 4 }}">{{ 'Type'|t('redirects') }}</th>
                    <th class="sortable" data-sort="string" data-index="{{ sites|length > 1 ? 6 : 5 }}">{{ 'Match'|t('redirects') }}</th>
                    <th class="sortable" data-sort="string" data-index="{{ sites|length > 1 ? 7 : 6 }}">{{ 'Label'|t('redirects') }}</th>
                    <th class="sortable" data-sort="number" data-index="{{ sites|length > 1 ? 8 : 7 }}">{{ 'Hits'|t('redirects') }}</th>
                    <th class="sortable" data-sort="string" data-index="{{ sites|length > 1 ? 9 : 8 }}">{{ 'Last Hit'|t('redirects') }}</th>
                    <th class="sortable" data-sort="string" data-index="{{ sites|length > 1 ? 10 : 9 }}">{{ 'Notes'|t('redirects') }}</th>
                    <th class="sortable" data-sort="string" data-index="{{ sites|length > 1 ? 11 : 10 }}">{{ 'Created'|t('redirects') }}</th>
                    <th class="sortable" data-sort="string" data-index="{{ sites|length > 1 ? 12 : 11 }}">{{ 'Created by'|t('redirects') }}</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for redirect in redirects %}
                    <tr data-id="{{ redirect.id }}">
                        <td><input type="checkbox" class="row-select" value="{{ redirect.id }}"></td>
                        <td data-value="{{ redirect.enabled ? '1' : '0' }}">
                            <button class="toggle-enabled btn small {% if redirect.enabled %}toggle-on{% endif %}"
                                    data-id="{{ redirect.id }}"
                                    title="{{ 'Toggle enabled'|t('redirects') }}">
                                {{ redirect.enabled ? 'On'|t('redirects') : 'Off'|t('redirects') }}
                            </button>
                        </td>
                        {% if sites|length > 1 %}
                            <td>{{ redirect.siteName }}</td>
                        {% endif %}
                        <td><a href="{{ cpUrl('redirects/' ~ redirect.id) }}">{{ redirect.fromUrl }}</a></td>
                        <td>{{ redirect.toUrl }}</td>
                        <td>{{ redirect.type }}</td>
                        <td>{{ redirect.matchType }}</td>
                        <td>{{ redirect.label ?? '' }}</td>
                        <td>{{ redirect.hitCount }}</td>
                        <td>{{ redirect.lastHitAt ?? '—' }}</td>
                        <td>{{ redirect.notes }}</td>
                        <td>{{ redirect.dateCreated }}</td>
                        <td>{{ redirect.createdByName ?? '—' }}</td>
                        <td class="thin">
                            <a href="{{ cpUrl('redirects/' ~ redirect.id) }}" class="btn small" title="{{ 'Edit'|t('redirects') }}">{{ 'Edit'|t('redirects') }}</a>
                            <button class="btn small delete-redirect" data-id="{{ redirect.id }}" title="{{ 'Delete'|t('redirects') }}">{{ 'Delete'|t('redirects') }}</button>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    {% else %}
        <p>{{ 'No redirects yet.'|t('redirects') }}</p>
    {% endif %}

    {% css %}
        .sortable-table th.sortable {
            cursor: pointer;
            user-select: none;
            white-space: nowrap;
        }
        .sortable-table th.sortable:hover {
            background-color: rgba(0, 0, 0, 0.05);
        }
        .sortable-table th.sortable::after {
            content: '';
            display: inline-block;
            width: 0;
            height: 0;
            margin-left: 5px;
            vertical-align: middle;
            border-left: 4px solid transparent;
            border-right: 4px solid transparent;
            border-top: 4px solid transparent;
            border-bottom: 4px solid transparent;
        }
        .sortable-table th.sortable.sort-asc::after {
            border-bottom: 4px solid currentColor;
            border-top: none;
        }
        .sortable-table th.sortable.sort-desc::after {
            border-top: 4px solid currentColor;
            border-bottom: none;
        }
        .btn.caution {
            color: #dc2626;
        }
        .toggle-enabled.toggle-on {
            background-color: #16a34a;
            color: #fff;
            border-color: #16a34a;
        }
        .toggle-enabled.toggle-on:hover {
            background-color: #15803d;
            border-color: #15803d;
        }
    {% endcss %}

    {% js %}
        // --- Search / filter ---
        (function() {
            var input = document.getElementById('redirectSearch');
            if (!input) return;

            input.addEventListener('input', function() {
                var query = this.value.toLowerCase();
                document.querySelectorAll('.sortable-table tbody tr').forEach(function(row) {
                    var text = row.textContent.toLowerCase();
                    row.style.display = text.includes(query) ? '' : 'none';
                });
            });
        })();

        // --- Select all / bulk actions ---
        (function() {
            var selectAll = document.getElementById('selectAll');
            var bulkBar = document.getElementById('bulkActions');
            var bulkCount = document.getElementById('bulkCount');
            if (!selectAll || !bulkBar) return;

            function getChecked() {
                return Array.from(document.querySelectorAll('.row-select:checked')).map(function(cb) {
                    return cb.value;
                });
            }

            function updateBulkBar() {
                var ids = getChecked();
                bulkCount.textContent = ids.length;
                bulkBar.style.display = ids.length > 0 ? 'flex' : 'none';
            }

            selectAll.addEventListener('change', function() {
                document.querySelectorAll('.row-select').forEach(function(cb) {
                    var row = cb.closest('tr');
                    if (row.style.display !== 'none') {
                        cb.checked = selectAll.checked;
                    }
                });
                updateBulkBar();
            });

            document.querySelectorAll('.row-select').forEach(function(cb) {
                cb.addEventListener('change', updateBulkBar);
            });

            function bulkAction(action) {
                var ids = getChecked();
                if (!ids.length) return;

                Craft.sendActionRequest('POST', 'redirects/redirects/' + action, {
                    data: { ids: ids }
                }).then(function() {
                    window.location.reload();
                }).catch(function() {
                    Craft.cp.displayError('{{ 'Bulk action failed.'|t('redirects')|e('js') }}');
                });
            }

            document.getElementById('bulkEnableBtn').addEventListener('click', function() {
                bulkAction('bulk-enable');
            });
            document.getElementById('bulkDisableBtn').addEventListener('click', function() {
                bulkAction('bulk-disable');
            });
            document.getElementById('bulkDeleteBtn').addEventListener('click', function() {
                if (confirm('{{ 'Are you sure you want to delete these redirects?'|t('redirects')|e('js') }}')) {
                    bulkAction('bulk-delete');
                }
            });

            document.getElementById('bulkChangeTypeBtn').addEventListener('click', function() {
                var ids = getChecked();
                if (!ids.length) return;
                var type = document.getElementById('bulkTypeSelect').value;

                Craft.sendActionRequest('POST', 'redirects/redirects/bulk-change-type', {
                    data: { ids: ids, type: type }
                }).then(function() {
                    window.location.reload();
                }).catch(function() {
                    Craft.cp.displayError('{{ 'Bulk action failed.'|t('redirects')|e('js') }}');
                });
            });
        })();

        // --- Sortable table ---
        (function() {
            var table = document.querySelector('.sortable-table');
            if (!table) return;

            var headers = table.querySelectorAll('th.sortable');
            var tbody = table.querySelector('tbody');
            var currentSort = { index: null, dir: 'asc' };

            headers.forEach(function(th) {
                th.addEventListener('click', function() {
                    var index = parseInt(th.dataset.index);
                    var type = th.dataset.sort;

                    if (currentSort.index === index) {
                        currentSort.dir = currentSort.dir === 'asc' ? 'desc' : 'asc';
                    } else {
                        currentSort.index = index;
                        currentSort.dir = 'asc';
                    }

                    headers.forEach(function(h) { h.classList.remove('sort-asc', 'sort-desc'); });
                    th.classList.add('sort-' + currentSort.dir);

                    var rows = Array.from(tbody.querySelectorAll('tr'));
                    rows.sort(function(a, b) {
                        var cellA = a.children[index];
                        var cellB = b.children[index];
                        var valA = cellA.dataset.value !== undefined ? cellA.dataset.value : cellA.textContent.trim().toLowerCase();
                        var valB = cellB.dataset.value !== undefined ? cellB.dataset.value : cellB.textContent.trim().toLowerCase();

                        if (type === 'number') {
                            valA = parseFloat(valA) || 0;
                            valB = parseFloat(valB) || 0;
                        }

                        var result = valA > valB ? 1 : valA < valB ? -1 : 0;
                        return currentSort.dir === 'desc' ? -result : result;
                    });

                    rows.forEach(function(row) { tbody.appendChild(row); });
                });
            });
        })();

        // --- Delete ---
        document.querySelectorAll('.delete-redirect').forEach(function(btn) {
            btn.addEventListener('click', function() {
                if (!confirm('{{ 'Are you sure you want to delete this redirect?'|t('redirects')|e('js') }}')) {
                    return;
                }

                var id = this.dataset.id;
                var row = this.closest('tr');

                Craft.sendActionRequest('POST', 'redirects/redirects/delete', {
                    data: { id: id }
                }).then(function() {
                    row.remove();
                    Craft.cp.displayNotice('{{ 'Redirect deleted.'|t('redirects')|e('js') }}');
                }).catch(function() {
                    Craft.cp.displayError('{{ 'Could not delete redirect.'|t('redirects')|e('js') }}');
                });
            });
        });

        // --- Toggle ---
        document.querySelectorAll('.toggle-enabled').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var button = this;
                var id = this.dataset.id;

                Craft.sendActionRequest('POST', 'redirects/redirects/toggle', {
                    data: { id: id }
                }).then(function(response) {
                    var enabled = response.data.enabled;
                    button.textContent = enabled ? '{{ 'On'|t('redirects')|e('js') }}' : '{{ 'Off'|t('redirects')|e('js') }}';
                    var cell = button.closest('td');
                    cell.dataset.value = enabled ? '1' : '0';
                    if (enabled) {
                        button.classList.add('toggle-on');
                    } else {
                        button.classList.remove('toggle-on');
                    }
                    Craft.cp.displayNotice(enabled ? '{{ 'Redirect enabled.'|t('redirects')|e('js') }}' : '{{ 'Redirect disabled.'|t('redirects')|e('js') }}');
                }).catch(function() {
                    Craft.cp.displayError('{{ 'Could not toggle redirect.'|t('redirects')|e('js') }}');
                });
            });
        });
    {% endjs %}
{% endblock %}
